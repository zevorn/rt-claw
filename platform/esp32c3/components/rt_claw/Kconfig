menu "rt-claw Configuration"

    # AI Engine credentials and tuning are configured at the top level
    # via Meson options or environment variables.  See claw_config.h.

    menu "WiFi"

        config RTCLAW_WIFI_SSID
            string "Default WiFi SSID"
            default ""
            help
                Build-time WiFi SSID. Can be overridden at runtime
                via /wifi_set shell command (saved to NVS).

        config RTCLAW_WIFI_PASS
            string "Default WiFi password"
            default ""
            help
                Build-time WiFi password. Can be overridden at runtime
                via /wifi_set shell command (saved to NVS).

    endmenu

    menu "Module Selection"

        config RTCLAW_SHELL_ENABLE
            bool "Enable interactive UART shell"
            default y
            help
                Chat-first UART shell. Direct input goes to AI,
                /commands for system. Disable to save RAM when
                using only IM channels (e.g. Feishu).

        config RTCLAW_LCD_ENABLE
            bool "Enable LCD display"
            default n
            help
                QEMU RGB framebuffer or SPI LCD panel.
                Disable if no display hardware is present.

        config RTCLAW_SWARM_ENABLE
            bool "Enable swarm intelligence"
            default y
            help
                Node discovery, heartbeat, and distributed task
                scheduling over UDP broadcast.

        config RTCLAW_SCHED_ENABLE
            bool "Enable task scheduler"
            default y
            help
                Timer-driven task execution engine.

        config RTCLAW_SKILL_ENABLE
            bool "Enable skill system"
            default y
            help
                Predefined prompt templates (draw, monitor, greet).

        menu "Tool Use"

            config RTCLAW_TOOL_GPIO
                bool "GPIO tools"
                default y
                help
                    gpio_set, gpio_get, gpio_config tools.

            config RTCLAW_TOOL_SYSTEM
                bool "System info tools"
                default y
                help
                    system_info, memory_info, system_restart tools.

            config RTCLAW_TOOL_LCD
                bool "LCD drawing tools"
                default n
                depends on RTCLAW_LCD_ENABLE
                help
                    lcd_fill, lcd_text, lcd_rect, lcd_line, lcd_circle tools.

            config RTCLAW_TOOL_SCHED
                bool "Scheduler tools"
                default y
                depends on RTCLAW_SCHED_ENABLE
                help
                    schedule_task, remove_task tools.

            config RTCLAW_TOOL_NET
                bool "Network (HTTP) tools"
                default y
                help
                    http_request tool for GET/POST requests.

        endmenu

    endmenu

endmenu
