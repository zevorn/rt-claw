menu "rt-claw Configuration"

    menu "AI Engine"

        config CLAW_AI_API_KEY
            string "LLM API Key"
            default ""
            help
                API key for LLM service (e.g. Claude, DeepSeek).
                Set via: idf.py menuconfig -> rt-claw -> AI Engine

        config CLAW_AI_API_URL
            string "LLM API endpoint URL"
            default "https://api.anthropic.com/v1/messages"
            help
                Full URL of the chat completion API endpoint.

        config CLAW_AI_MODEL
            string "LLM model name"
            default "claude-sonnet-4-6"
            help
                Model identifier sent in the API request.

        config CLAW_AI_MAX_TOKENS
            int "Max response tokens"
            default 1024
            range 64 4096

        config CLAW_AI_MEMORY_MAX_MSGS
            int "Max conversation memory messages"
            default 20
            range 4 64
            help
                Maximum number of messages stored in AI conversation memory.
                When full, the oldest user+assistant pair is dropped.

    endmenu

    menu "Feishu (Lark) Integration"

        config CLAW_FEISHU_ENABLE
            bool "Enable Feishu IM integration"
            default n
            help
                Connect to Feishu via WebSocket long connection.
                Receives user messages and replies through AI engine.

        config CLAW_FEISHU_APP_ID
            string "Feishu App ID"
            default ""
            depends on CLAW_FEISHU_ENABLE
            help
                App ID from Feishu Open Platform (open.feishu.cn).

        config CLAW_FEISHU_APP_SECRET
            string "Feishu App Secret"
            default ""
            depends on CLAW_FEISHU_ENABLE
            help
                App Secret from Feishu Open Platform.

    endmenu

endmenu
