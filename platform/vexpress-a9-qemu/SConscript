import os
from building import *

cwd = GetCurrentDir()
project_root = os.path.normpath(os.path.join(cwd, '..', '..'))
objs = []

# --- Local subdirectories (drivers, applications) ---
for d in os.listdir(cwd):
    path = os.path.join(cwd, d)
    if os.path.isfile(os.path.join(path, 'SConscript')):
        objs = objs + SConscript(os.path.join(d, 'SConscript'))

# rt-claw headers (unified include/ directory)
claw_inc = [
    os.path.join(project_root, 'include'),
    os.path.join(project_root, 'vendor', 'lib', 'cjson'),
]
Env.AppendUnique(CPPPATH=[os.path.abspath(p) for p in claw_inc])

# Link pre-built libraries from Meson (build/vexpress-a9-qemu/)
build_dir = os.path.join(project_root, 'build', 'vexpress-a9-qemu')
Env.AppendUnique(LIBS=['rtclaw', 'osal', 'cjson'])
Env.AppendUnique(LIBPATH=[
    os.path.join(build_dir, 'claw'),
    os.path.join(build_dir, 'osal'),
    os.path.join(build_dir, 'vendor', 'lib', 'cjson'),
])

Return('objs')
