# rt-claw ESP32-S3 SDK configuration defaults

# FreeRTOS
CONFIG_FREERTOS_HZ=1000
CONFIG_FREERTOS_TIMER_TASK_STACK_DEPTH=4096

# System
CONFIG_ESP_SYSTEM_EVENT_TASK_STACK_SIZE=4096

# WiFi (enable later for real hardware)
# CONFIG_ESP_WIFI_ENABLED=y

# Ethernet — OpenCores MAC for QEMU
CONFIG_ETH_ENABLED=y
CONFIG_ETH_USE_OPENETH=y

# LWIP
CONFIG_LWIP_DNS_SUPPORT_MDNS_QUERIES=n

# Console / UART
CONFIG_ESP_CONSOLE_UART_DEFAULT=y
CONFIG_ESP_CONSOLE_UART_BAUDRATE=115200

# Flash
CONFIG_ESPTOOLPY_FLASHSIZE_4MB=y
CONFIG_ESPTOOLPY_FLASHSIZE="4MB"

# Partition table
CONFIG_PARTITION_TABLE_CUSTOM=y
CONFIG_PARTITION_TABLE_CUSTOM_FILENAME="partitions.csv"

# TLS / Certificate bundle (for HTTPS API calls)
CONFIG_MBEDTLS_CERTIFICATE_BUNDLE=y
CONFIG_MBEDTLS_CERTIFICATE_BUNDLE_DEFAULT_FULL=y
CONFIG_MBEDTLS_SSL_PROTO_TLS1_3=y

# Main task needs more stack for TLS + JSON parsing
CONFIG_ESP_MAIN_TASK_STACK_SIZE=16384

# QEMU chip revision (efuse reports v0.0)
CONFIG_ESP32S3_REV_MIN_0=y

# Optimization
CONFIG_COMPILER_OPTIMIZATION_SIZE=y

# Newlib
CONFIG_NEWLIB_STDIN_LINE_ENDING_LF=y

# Feishu (Lark) Integration
# CONFIG_CLAW_FEISHU_ENABLE=y
# Set App ID and Secret via: idf.py menuconfig -> rt-claw -> Feishu
