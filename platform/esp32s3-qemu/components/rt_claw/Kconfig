menu "rt-claw Configuration"

    menu "AI Engine"

        config RTCLAW_AI_API_KEY
            string "LLM API Key"
            default ""
            help
                API key for LLM service (e.g. Claude, DeepSeek).
                Set via: idf.py menuconfig -> rt-claw -> AI Engine

        config RTCLAW_AI_API_URL
            string "LLM API endpoint URL"
            default "https://api.anthropic.com/v1/messages"
            help
                Full URL of the chat completion API endpoint.

        config RTCLAW_AI_MODEL
            string "LLM model name"
            default "claude-sonnet-4-6"
            help
                Model identifier sent in the API request.

        config RTCLAW_AI_MAX_TOKENS
            int "Max response tokens"
            default 1024
            range 64 4096

        config RTCLAW_AI_CONTEXT_SIZE
            int "AI response buffer size (bytes)"
            default 8192
            range 4096 65536
            help
                Size of the HTTP response buffer for AI API calls.
                Larger values allow longer AI responses but use more RAM.

        config RTCLAW_AI_MEMORY_MAX_MSGS
            int "Max conversation memory messages"
            default 20
            range 4 64
            help
                Maximum number of messages stored in AI conversation memory.
                When full, the oldest user+assistant pair is dropped.

    endmenu

    menu "Module Selection"

        config RTCLAW_SHELL_ENABLE
            bool "Enable interactive UART shell"
            default n
            help
                Chat-first UART shell. Direct input goes to AI,
                /commands for system. Disable to save RAM when
                using only IM channels (e.g. Feishu).

        config RTCLAW_LCD_ENABLE
            bool "Enable LCD display"
            default y
            help
                QEMU RGB framebuffer or SPI LCD panel.
                Disable if no display hardware is present.

        config RTCLAW_SWARM_ENABLE
            bool "Enable swarm intelligence"
            default y
            help
                Node discovery, heartbeat, and distributed task
                scheduling over UDP broadcast.

        config RTCLAW_SCHED_ENABLE
            bool "Enable task scheduler"
            default y
            help
                Timer-driven task execution engine.

        config RTCLAW_SKILL_ENABLE
            bool "Enable skill system"
            default y
            help
                Predefined prompt templates (draw, monitor, greet).

        menu "Tool Use"

            config RTCLAW_TOOL_GPIO
                bool "GPIO tools"
                default y
                help
                    gpio_set, gpio_get, gpio_config tools.

            config RTCLAW_TOOL_SYSTEM
                bool "System info tools"
                default y
                help
                    system_info, memory_info, system_restart tools.

            config RTCLAW_TOOL_LCD
                bool "LCD drawing tools"
                default y
                depends on RTCLAW_LCD_ENABLE
                help
                    lcd_fill, lcd_text, lcd_rect, lcd_line, lcd_circle tools.

            config RTCLAW_TOOL_SCHED
                bool "Scheduler tools"
                default y
                depends on RTCLAW_SCHED_ENABLE
                help
                    schedule_task, remove_task tools.

            config RTCLAW_TOOL_NET
                bool "Network (HTTP) tools"
                default y
                help
                    http_request tool for GET/POST requests.

        endmenu

    endmenu

    menu "Feishu (Lark) Integration"

        config RTCLAW_FEISHU_ENABLE
            bool "Enable Feishu IM integration"
            default n
            help
                Connect to Feishu via WebSocket long connection.
                Receives user messages and replies through AI engine.

        config RTCLAW_FEISHU_APP_ID
            string "Feishu App ID"
            default ""
            depends on RTCLAW_FEISHU_ENABLE
            help
                App ID from Feishu Open Platform (open.feishu.cn).

        config RTCLAW_FEISHU_APP_SECRET
            string "Feishu App Secret"
            default ""
            depends on RTCLAW_FEISHU_ENABLE
            help
                App Secret from Feishu Open Platform.

    endmenu

endmenu
